<UserControl x:Class="Aksl.Modules.MenuSub.Views.MenuSubHubView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:acview="clr-namespace:Aksl.ActiveContents.Views;assembly=Aksl.ActiveContents"
             xmlns:inf="clr-namespace:Aksl.Infrastructure;assembly=Aksl.Infrastructure"
             xmlns:views="clr-namespace:Aksl.Modules.MenuSub.Views"
             mc:Ignorable="d"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <!--<Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>-->
        <Grid  Grid.Row="0"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Stretch"
               Background="{StaticResource PrimaryThemeBrush}">
            <views:HierarchicalMenusView DataContext="{Binding Path=HierarchicalMenus}"
                                         HorizontalAlignment="Stretch"
                                         VerticalContentAlignment="Center"
                                         Margin="1,1,1,1" />
        </Grid>

        <Separator Grid.Row="1"
                   Margin="0,1,0,0"
                   Height="8"
                   BorderBrush="#193441"
                   Grid.RowSpan="2"
                   VerticalAlignment="Top" />
        <!--<GridSplitter  Grid.Row="1"
                       Margin="0,1,0,0" HorizontalAlignment="Stretch"
                       BorderBrush="#193441" />-->

        <!--<Border Margin="0"
                Background="WhiteSmoke"
                HorizontalAlignment="Stretch"
                BorderThickness="2"
                CornerRadius="5" Grid.Row="2"
                BorderBrush="Black">-->
        <acview:RandomActiveContentView  Grid.Row="2"
                                         DataContext="{Binding Path=BottomActiveContentViewModel}"
                                         Margin="2">
            <acview:RandomActiveContentView.RenderTransform>
                <TransformGroup>
                    <ScaleTransform />
                    <SkewTransform />
                    <RotateTransform />
                    <TranslateTransform />
                </TransformGroup>
            </acview:RandomActiveContentView.RenderTransform>
        </acview:RandomActiveContentView>
        <!--</Border>-->
    </Grid>

</UserControl>
