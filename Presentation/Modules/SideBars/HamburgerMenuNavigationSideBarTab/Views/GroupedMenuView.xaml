                                <Setter Property="Stroke"
                                        TargetName="arrow"
                                        Value="{StaticResource Expander.Disabled.Arrow.Stroke}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
