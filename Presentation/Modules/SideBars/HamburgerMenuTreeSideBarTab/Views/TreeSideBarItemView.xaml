<UserControl x:Class="Aksl.Modules.HamburgerMenuTreeSideBarTab.Views.TreeSideBarItemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ei="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:materialDesign="clr-namespace:Aksl.Toolkit.Controls;assembly=Aksl.Toolkit.Controls"
             mc:Ignorable="d">
    <UserControl.Resources>

        <Style x:Key="labelStyle"
               TargetType="{x:Type Label}">
            <Setter Property="IsEnabled"
                    Value="{Binding IsEnabled,Mode=TwoWay}" />
            <Setter Property="Content">
                <Setter.Value>
                    <DockPanel>
                        <materialDesign:PackIcon DockPanel.Dock="Left"
                                                 Kind="{Binding Path=IconKind,Mode=OneWay}"
                                                 Foreground="Gray"
                                                 Background="Transparent"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                        <TextBlock 
                                   Text="{Binding Path=Title,Mode=OneWay}"
                                   Margin="10,0,0,0"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap">
                        </TextBlock>
                        <materialDesign:PackIcon  DockPanel.Dock="Right"
                                                  Width="24"
                                                  Height="24"
                                                  Visibility="{Binding Path=IsNavigationToRightContent,Converter={StaticResource booleanToVisibilityConverter}}"
                                                  Kind="ArrowRightThick"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"
                                                  Margin="60,1,1,1" />
                    </DockPanel>
                    <!--<Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="48" />
                        </Grid.ColumnDefinitions>
                        <materialDesign:PackIcon Grid.Column="0"  Kind="{Binding Path=IconKind,Mode=OneWay}"
                                                 Foreground="Gray"
                                                 Background="Transparent"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding Path=Title,Mode=OneWay}"
                                   Margin="8,0,50,0"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap">
                                 
                        </TextBlock>
                        <materialDesign:PackIcon Grid.Column="2"
                                                 Width="24"
                                                 Height="24"
                                                 Visibility="{Binding Path=IsNavigationToRightContent,Converter={StaticResource booleanToVisibilityConverter}}"
                                                 Kind="ArrowRightThick"
                                              
                                                 HorizontalAlignment="Right"
                                                 VerticalAlignment="Center"
                                                 Margin="1,1,1,1" />
                    </Grid>-->
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!--<Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Background"
                            Value="Transparent" />
                </Trigger>
                <DataTrigger Binding="{Binding IsSelected,Mode=TwoWay}"
                             Value="True">
                    <Setter Property="Background"
                            Value="#EEEEEEEE" />
                </DataTrigger>-->
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <!--<StackPanel Orientation="Horizontal">-->
        <Grid>
        <Label x:Name="treeBarItemLabel"
               Style="{StaticResource labelStyle}">
            <ei:Interaction.Triggers>
                <ei:DataTrigger Binding="{Binding Path=IsTopLevelItem,Mode=OneWay}"
                                Comparison="Equal"
                                Value="True">
                    <ei:ChangePropertyAction PropertyName="FontSize"
                                             Value="18" />
                    <ei:ChangePropertyAction PropertyName="FontWeight"
                                             Value="Bold" />
                </ei:DataTrigger>
                <ei:DataTrigger Binding="{Binding Path=IsTopLevelHeader,Mode=OneWay}"
                                Comparison="Equal"
                                Value="True">
                    <ei:ChangePropertyAction PropertyName="FontSize"
                                             Value="18" />
                    <ei:ChangePropertyAction PropertyName="FontWeight"
                                             Value="Bold" />
                </ei:DataTrigger>
                <ei:DataTrigger Binding="{Binding Path=IsSubmenuItem,Mode=OneWay}"
                                Comparison="Equal"
                                Value="True">
                    <ei:ChangePropertyAction PropertyName="FontSize"
                                             Value="16.5" />
                    <ei:ChangePropertyAction PropertyName="FontWeight"
                                             Value="Light" />
                </ei:DataTrigger>
                <ei:DataTrigger Binding="{Binding Path=IsSubmenuHeader,Mode=OneWay}"
                                Comparison="Equal"
                                Value="True">
                    <ei:ChangePropertyAction PropertyName="FontSize"
                                             Value="17.5" />
                    <ei:ChangePropertyAction PropertyName="FontWeight"
                                             Value="Bold" />
                </ei:DataTrigger>
            </ei:Interaction.Triggers>
            </Label>
        </Grid>
    <!--</StackPanel>-->
</UserControl>
