<UserControl x:Class="Aksl.Modules.HamburgerMenuSideBarTab.Views.HamburgerMenuSideBarItemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:ei="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:materialDesign="clr-namespace:Aksl.Toolkit.Controls;assembly=Aksl.Toolkit.Controls"
             d:DesignHeight="200"
             d:DesignWidth="500">
    <UserControl.Resources>

        <Storyboard x:Key="IndicatorStoryboard">
            <DoubleAnimation Storyboard.TargetName="IndicatorRectangle"
                             Storyboard.TargetProperty="(UIElement.Opacity)"
                             Duration="0:0:2"
                             From="0.0"
                             To="2.0" />
        </Storyboard>

        <Style x:Key="rectangleStyle"
               TargetType="{x:Type Rectangle}">
            <Setter Property="Fill"
                    Value="Red" />
            <Setter Property="Width"
                    Value="4" />
            <Setter Property="HorizontalAlignment"
                    Value="Left" />
        </Style>

        <Style x:Key="labelStyle"
               TargetType="{x:Type Label}">
            <Setter Property="Margin"
                    Value="4,0,0,0" />
            <!--<Setter Property="FontSize"
                  Value="16" />-->
            <Setter Property="IsEnabled"
                    Value="{Binding IsEnabled,Mode=TwoWay}" />
            <Setter Property="Content">
                <Setter.Value>
                    <materialDesign:PackIcon Kind="{Binding Path=IconKind,Mode=OneWay}"
                                             Foreground="Gray"
                                             Background="Transparent"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!--<DataTrigger Binding="{Binding Path=IsPaneOpen}"
                             Value="True">
                    <Setter Property="ToolTip"
                            Value="{x:Null}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Path=IsPaneOpen}"
                             Value="False">
                    <Setter Property="ToolTip"
                            Value="{Binding Title}" />
                </DataTrigger>-->
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Height="30"
          Width="{Binding Path=Width,RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type ListViewItem}}}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="48" />
            <ColumnDefinition Width="210" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Rectangle x:Name="IndicatorRectangle"
                   Grid.Column="0"
                   Visibility="{Binding Path=IsSelected,Converter={StaticResource booleanToVisibilityConverter}}"
                   Style="{StaticResource rectangleStyle}">
            <ei:Interaction.Triggers>
                <ei:DataTrigger Binding="{Binding Path=IsSelected,Mode=OneWay}"
                                Comparison="Equal"
                                Value="True">
                    <ei:ControlStoryboardAction ControlStoryboardOption="Play"
                                                Storyboard="{StaticResource IndicatorStoryboard}">
                    </ei:ControlStoryboardAction>
                </ei:DataTrigger>
            </ei:Interaction.Triggers>
        </Rectangle>

        <Label Grid.Column="0"
               Style="{StaticResource labelStyle}">
        </Label>

        <TextBlock Grid.Column="1"
                   Text="{Binding Path=Title,Mode=OneWay}"
                   IsEnabled="{Binding Path=IsEnabled}"
                   Margin="1,0,1,0"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis"
                   TextWrapping="NoWrap">
        </TextBlock>

        <materialDesign:PackIcon Grid.Column="2"
                                 Width="24"
                                 Height="24"
                                 Visibility="{Binding Path=IsShowArrow,Converter={StaticResource booleanToVisibilityConverter}}"
                                 Kind="ArrowRightThin"
                                 Foreground="Black"
                                 Background="Transparent"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Center"
                                 Margin="15,1,1,1" />
    </Grid>

    <!--<DockPanel Height="30"
               Width="{Binding Path=Width,RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type ListViewItem}}}">

        <Rectangle DockPanel.Dock="Left"
                   Visibility="{Binding Path=IsSelected,Converter={StaticResource booleanToVisibilityConverter}}"
                   Style="{StaticResource rectangleStyle}">
            <ei:Interaction.Triggers>
                <ei:DataTrigger Binding="{Binding Path=IsSelected,Mode=OneWay}"
                                Comparison="Equal"
                                Value="True">
                    <ei:ControlStoryboardAction ControlStoryboardOption="Play"
                                                Storyboard="{StaticResource IndicatorStoryboard}">
                    </ei:ControlStoryboardAction>
                </ei:DataTrigger>
            </ei:Interaction.Triggers>
        </Rectangle>

        <TextBlock 
                   Text="{Binding Path=Title,Mode=OneWay}"
                   IsEnabled="{Binding Path=IsEnabled}"
                   Margin="1,0,0,0"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis"
                   TextWrapping="NoWrap">
        </TextBlock>

        <materialDesign:PackIcon DockPanel.Dock="Right"
                                 Width="24"
                                 Height="24"
                                 Kind="ArrowRightCircleOutline"
                                 Foreground="Gray"
                                 Background="Transparent"
                                 HorizontalAlignment="Right"
                                 VerticalAlignment="Center"
                                 Margin="1,1,1,1" />
    </DockPanel>-->
</UserControl>
