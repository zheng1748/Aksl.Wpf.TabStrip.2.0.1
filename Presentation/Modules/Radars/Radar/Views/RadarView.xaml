<UserControl x:Class="Aksl.Modules.RadarMap.Views.RadarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:ei="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:views="clr-namespace:Aksl.Modules.RadarMap.Views"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <UserControl.Resources>

        <Storyboard x:Key="FanCirceStoryboard">
            <DoubleAnimation Storyboard.TargetName="Template.PathFan"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                             RepeatBehavior="Forever"
                             BeginTime="0:0:0"
                             Duration="0:0:2"
                             From="0"
                             To="360">
            </DoubleAnimation>
        </Storyboard>
        
        <Style x:Key="radarContainerStyle"
               TargetType="{x:Type ContentPresenter}">
            <Setter Property="Canvas.Left"
                    Value="{Binding Path=Left}" />
            <Setter Property="Canvas.Top"
                    Value="{Binding Path=Top}" />
        </Style>

        <ControlTemplate x:Key="ItemsControlTemplateKey"
                         TargetType="{x:Type ItemsControl}">

            <Grid Background="WhiteSmoke"
                  Margin="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="2*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>
                
                <ItemsControl x:Name="ic"
                              Grid.RowSpan="2"
                              Grid.ColumnSpan="2"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center"
                              ItemsSource="{Binding Path=RadarCircles,RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type UserControl}}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Grid IsItemsHost="True" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Ellipse Width="{Binding Path=Width}"
                                     Height="{Binding Path=Height}"
                                     Stroke="{Binding Path=Color}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ItemsControl Grid.ColumnSpan="2"
                              Grid.RowSpan="2"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center"
                              x:Name="ic2"
                              ItemsSource="{Binding Path=RadarLines,RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type UserControl}}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Grid IsItemsHost="True" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Line X1="{Binding Start.X}"
                                  Y1="{Binding Start.Y}"
                                  X2="{Binding End.X}"
                                  Y2="{Binding End.Y}"
                                  Stroke="{Binding Color}"
                                  StrokeThickness="{Binding Thickness}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                
                <ItemsPresenter Grid.ColumnSpan="2"
                                Grid.RowSpan="2"
                                Width="{Binding Path=RadarFullWidth,RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type UserControl}}}"
                                Height="{Binding Path=RadarFullWidth,RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type UserControl}}}" />

                <Path x:Name="PathFan"
                      Grid.ColumnSpan="2"
                      Stretch="Uniform"
                      VerticalAlignment="Center"
                      RenderTransformOrigin="0.5,1"
                      Data="{Binding Path=ScanningPath,RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type UserControl}}}"
                      Fill="{Binding Path=ScanningColor,RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type UserControl}}}">
                    <Path.RenderTransform>
                        <RotateTransform x:Name="rtf" />
                    </Path.RenderTransform>
                </Path>

                <ItemsPresenter Grid.ColumnSpan="2"
                                Grid.RowSpan="2" />
            </Grid>

            <ControlTemplate.Triggers>
                <DataTrigger Binding="{Binding Path=Play,RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type UserControl}}}"
                             Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard x:Name="bs">
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="PathFan"
                                                 Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                 RepeatBehavior="Forever"
                                                 BeginTime="0:0:0"
                                                 Duration="0:0:2"
                                                 From="0"
                                                 To="360">
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                </DataTrigger>
                <DataTrigger Binding="{Binding Path=Play,RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type UserControl}}}"
                             Value="False">
                    <DataTrigger.EnterActions>
                        <RemoveStoryboard BeginStoryboardName="bs">
                        </RemoveStoryboard>
                    </DataTrigger.EnterActions>
                </DataTrigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ItemsPanelTemplate x:Key="radarItemsPanelTemplate">
            <Canvas />
        </ItemsPanelTemplate>

        <DataTemplate x:Key="radarDataTemplate">
            <views:RadarItemView />
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="WhiteSmoke"
          Margin="0">
        <ItemsControl Template="{StaticResource ItemsControlTemplateKey}"
                      ItemsSource="{Binding RadarItems,RelativeSource={RelativeSource Mode=FindAncestor,AncestorType={x:Type UserControl}}}"
                      ItemsPanel="{StaticResource radarItemsPanelTemplate}"
                      ItemContainerStyle="{Binding Source={StaticResource radarContainerStyle}}"
                      ItemTemplate="{Binding Source={StaticResource radarDataTemplate}}">
            <!--<ei:Interaction.Triggers>
                <ei:DataTrigger Binding="{Binding Path=Play}"
                                Comparison="Equal"
                                Value="True">
                    <ei:ControlStoryboardAction ControlStoryboardOption="Play"
                                                Storyboard="{StaticResource FanCirceStoryboard}" />
                </ei:DataTrigger>
            </ei:Interaction.Triggers>-->
        </ItemsControl>
    </Grid>
</UserControl>
