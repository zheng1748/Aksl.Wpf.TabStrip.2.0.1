<UserControl x:Class="Aksl.TabBits.Views.TabContentView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ei="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:views="clr-namespace:Aksl.TabBits.Views"
             xmlns:viewmodels="clr-namespace:Aksl.TabBits.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <UserControl.Resources>

        <ItemsPanelTemplate x:Key="tabContentItemsPanelTemplate">
            <Grid></Grid>
        </ItemsPanelTemplate>

        <DataTemplate x:Key="tabContentDataTemplate"
                      DataType="{x:Type viewmodels:TabContentItemViewModel}">
            <views:TabContentItemView />
        </DataTemplate>

        <Style x:Key="tabContentListViewStyle"
               TargetType="{x:Type ListView}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListView}">
                        <Border CornerRadius="2"
                                BorderThickness="2">
                            <ScrollViewer VerticalScrollBarVisibility="Disabled"
                                          HorizontalScrollBarVisibility="Auto">
                                <ItemsPresenter />
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="tabContentListViewItemStyle"
               TargetType="{x:Type ListViewItem}">
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="IsSelected"
                    Value="{Binding IsSelected,Mode=TwoWay}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListViewItem}">
                        <Border Name="BD_Collector"
                                BorderThickness="1"
                                BorderBrush="Black"
                                CornerRadius="2"
                                Margin="0,0,5,0">
                            <ContentPresenter x:Name="ContentPresenter"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Content="{TemplateBinding Content}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="BD_Collector"
                                        Property="Background"
                                        Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter TargetName="BD_Collector"
                                        Property="Background"
                                        Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ItemsControl x:Name="TabContentItemsControl"
                  ItemsSource="{Binding Path=ActiveTabContentItems}"
                  ItemContainerStyle="{Binding Source={StaticResource tabContentItemsPanelTemplate}}"
                  ItemTemplate="{Binding Source={StaticResource tabContentDataTemplate}}">
    </ItemsControl>

    <!--<ListView ItemsSource="{Binding Path=ActiveTabContentItems}"
              Style="{StaticResource tabContentListViewStyle}"
              ItemsPanel="{StaticResource tabContentItemsPanelTemplate}"
              ItemContainerStyle="{StaticResource tabContentListViewItemStyle}"
              ItemTemplate="{StaticResource tabContentDataTemplate}"
              SelectionMode="Single"
              SelectedItem="{Binding Path=SelectedTabContentItem,Mode=TwoWay}"
              VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
    </ListView>-->

</UserControl>
