<UserControl x:Class="Aksl.TabBits.Views.TabHeaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ei="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:views="clr-namespace:Aksl.TabBits.Views"
             xmlns:viewmodels="clr-namespace:Aksl.TabBits.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <UserControl.Resources>

        <!--<ItemsPanelTemplate x:Key="tabHeaderItemsPanelTemplate">
            <WrapPanel Width="Auto"
                       Orientation="Horizontal" />
        </ItemsPanelTemplate>

        <DataTemplate x:Key="tabHeaderDataTemplate"
                      DataType="{x:Type viewmodels:TabHeaderItemViewModel}">
            <views:TabHeaderItemView/>
        </DataTemplate>-->

        <DataTemplate x:Key="tabHeaderDataTemplate"
                      DataType="{x:Type viewmodels:TabHeaderItemViewModel}">
            <views:TabHeaderItemView />
        </DataTemplate>

        <ItemsPanelTemplate x:Key="tabHeaderItemsTemplate">
            <WrapPanel Width="Auto"
                       Orientation="Horizontal" />
        </ItemsPanelTemplate>

        <Style x:Key="tabHeaderListViewStyle"
               TargetType="{x:Type ListView}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListView}">
                        <Border CornerRadius="2"
                                BorderThickness="2">
                            <!--<ScrollViewer VerticalScrollBarVisibility="Disabled"
                                          HorizontalScrollBarVisibility="Auto">-->
                                <ItemsPresenter />
                            <!--</ScrollViewer>-->
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="tabHeaderListViewItemStyle"
               TargetType="{x:Type ListViewItem}">
            <Setter Property="Cursor"
                    Value="Hand" />
            <Setter Property="IsSelected"
                    Value="{Binding IsSelected,Mode=TwoWay}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListViewItem}">
                        <Border Name="BD_Collector"
                                BorderThickness="1"
                                BorderBrush="Black"
                                CornerRadius="2"
                                Margin="0,0,5,0">
                            <!--<Label Content="{Binding}"
               VerticalContentAlignment="Center"
               HorizontalContentAlignment="Center"
               FontSize="13" />-->
                            <ContentPresenter x:Name="ContentPresenter"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Content="{TemplateBinding Content}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="BD_Collector"
                                        Property="Background"
                                        Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter TargetName="BD_Collector"
                                        Property="Background"
                                        Value="Green" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <!--<ScrollViewer HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Hidden">
        <ItemsControl ItemsSource="{Binding Path=TabHeaderItems}"
                      ItemContainerStyle="{Binding Source={StaticResource tabHeaderItemsPanelTemplate}}"
                      ItemTemplate="{Binding Source={StaticResource tabHeaderDataTemplate}}"
                      Background="WhiteSmoke">
        </ItemsControl>
    </ScrollViewer>-->

    <ListView ItemsSource="{Binding Path=ActiveTabHeaderItems}"
              Style="{StaticResource tabHeaderListViewStyle}"
              ItemsPanel="{StaticResource tabHeaderItemsTemplate}"
              ItemContainerStyle="{StaticResource tabHeaderListViewItemStyle}"
              ItemTemplate="{StaticResource tabHeaderDataTemplate}"
              SelectionMode="Single"
              SelectedItem="{Binding Path=SelectedTabHeaderItem,Mode=TwoWay}"
              VerticalAlignment="Center">
    </ListView>

</UserControl>
