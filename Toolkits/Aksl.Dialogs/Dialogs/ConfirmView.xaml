<UserControl x:Class="Aksl.Dialogs.Views.ConfirmView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:materialDesign="clr-namespace:Aksl.Toolkit.Controls;assembly=Aksl.Toolkit.Controls"
             mc:Ignorable="d"
             prism:ViewModelLocator.AutoWireViewModel="True">
    <UserControl.Resources>
    </UserControl.Resources>
    <Grid  Width="{Binding Path=Width}"
            Height="{Binding Path=Height}"
            Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="1" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0"
                Margin="0"
                Background="WhiteSmoke"
                CornerRadius="5"
                BorderThickness="3"
                BorderBrush="WhiteSmoke">
            <TextBlock Margin="7"
                       Text="{Binding Message,Mode=OneWay}"
                       TextWrapping="Wrap"
                       FontSize="16"
                       Foreground="Black" />
        </Border>
        <Border Grid.Row="2"
                Background="WhiteSmoke"
                CornerRadius="2"
                BorderThickness="2"
                BorderBrush="GhostWhite">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <Button x:Name="OkButton"
                        Command="{Binding Path=OkCommand,Mode=OneWay}"
                        Content="{Binding OkText,Mode=OneWay}"
                        Width="60"
                        Height="20"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left"
                        Margin="0,5,40,5">
                </Button>
                <Button x:Name="CancelButton"
                        Visibility="{Binding Path=CancelButtonVisibility}"
                        Content="{Binding CancelText,Mode=OneWay}"
                        Command="{Binding CancelCommand,Mode=OneWay}"
                        Width="60"
                        Height="20"
                        HorizontalAlignment="Right"
                        Margin="0,5,0,5">
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
